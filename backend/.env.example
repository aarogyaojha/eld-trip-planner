# Copy this file to .env and fill in real values. Never commit .env.

DJANGO_SECRET_KEY=replace-with-a-long-random-value
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list. Must match your deployed frontend origin exactly
# (scheme + host + port), no wildcards.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Leave unset to use local SQLite. Set to a Postgres URL in any environment
# where data must survive restarts/redeploys, e.g.:
# DATABASE_URL=postgres://user:password@host:5432/dbname
